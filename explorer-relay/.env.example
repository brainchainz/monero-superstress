# monerod connection
MONEROD_HOST=127.0.0.1
MONEROD_RPC_PORT=18081
MONEROD_ZMQ_PORT=18082

# Fallback public nodes (comma-separated https URLs); used when local RPC fails
MONEROD_FALLBACK_NODES=https://node.moneroworld.com:18089,https://node.sethforprivacy.com:18089,https://xmr-node.cakewallet.com:18081,https://nodes.hashvault.pro:18081

# Relay server
SERVER_PORT=3001
CORS_ORIGINS=https://xmr.irish,https://www.xmr.irish,http://localhost:3000,http://localhost:5173

# SQLite path
DB_PATH=./data/relay.db

# Logging
LOG_LEVEL=info
